{
  "expo": {
    "name": "Ely - Asistent Vocal",
    "slug": "ely-voice-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ely-assistant",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Detectează obstacole pentru navigare sigură",
        "NSMicrophoneUsageDescription": "Ascultă comenzile tale vocale",
        "NSSpeechRecognitionUsageDescription": "Înțelege comenzile vocale",
        "NSContactsUsageDescription": "Apelează contactele tale prin voce"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.SEND_SMS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Detectează obstacole pentru navigare sigură"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
